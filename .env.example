# ============================================
# 指南帮旅游 - 环境变量配置
# Guide to Hainan Automation System
# ============================================

# --- DeepSeek API (用于 AI 内容生成) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# --- WordPress API ---
WP_SITE_URL=https://www.zhinanlvyou.com
WP_API_BASE=https://www.zhinanlvyou.com/wp-json/wp/v2
WP_USERNAME=
WP_APPLICATION_PASSWORD=
WP_AUTH_ENDPOINT=https://www.zhinanlvyou.com/wp-json/jwt-auth/v1/token

# --- 发布控制 ---
AUTO_PUBLISH=false
WP_POST_STATUS=draft

# --- AI 提供商（mock 模式为本地模板，空则自动降级为 mock）---
AI_PROVIDER=

# --- 文章生成配置 ---
DAILY_ZH=2
DAILY_EN=2
DAILY_RU=1
DAILY_KO=1
DAILY_JA=1
DAILY_TH=1

# --- 视频脚本 ---
DAILY_VIDEO_SCRIPTS=3

# --- 日志级别 ---
LOG_LEVEL=info

# --- 人工确认提醒 ---
HUMAN_CONFIRM_REQUIRED=true
